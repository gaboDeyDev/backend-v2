{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "es2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "paths": {
      "@dey/prisma/undostres": ["schemas/undostres_prisma/generated"],
      "@dey/prisma/undostres/*": ["schemas/undostres_prisma/generated/*"],
      "@dey/prisma/accounts": ["schemas/generated/prisma/accounts"],
      "@dey/prisma/accounts/*": ["schemas/generated/prisma/accounts/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
