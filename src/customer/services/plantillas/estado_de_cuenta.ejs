      align-items: center;
    }

    .label-graph-v2 {
      width: 140px;
      background-color: #ccc;
      padding: 4px 6px;
      box-sizing: border-box;
      font-size: 14px;
      border-bottom: 1px solid #757573;
      border-top: 1px solid #757573;
      border-right: 1px solid #757573;
      border-left:1px solid #757573;
    }

    .bar-container-graph-v2 {
      flex-grow: 1;
      margin: 0 0;
      height: 24px;
      position: relative;
    }

    .bar-graph-v2 {
      height: 100%;
      background: linear-gradient(to right, #999, #ddd);
      border-bottom: 1px solid #757573;
      border-top: 1px solid #757573;
      border-right: 1px solid #757573;
      padding: 0 4px;
    }

    .amount-graph-v2 {
      width: 70px;
      text-align: right;
      font-size: 14px;
    }

    .money {
      text-align: right;
      font-size: 14px;
      margin: 0 8px;
    }

    p {
      text-align: justify;
    }
  </style>
