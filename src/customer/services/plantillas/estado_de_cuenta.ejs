  <style>
  .card {
    border: 2px solid #757573;
    border-radius: 10px;
    margin: 20px 0;
    width: 48%;
    font-family: Arial, sans-serif;
    font-size: 14px;
    height: fit-content;
  }

  .card-2 {
    border: 2px solid #757573;
    border-radius: 10px;
    margin: 20px 0;
    margin-top: 10px;
    width: 100%;
    font-family: Arial, sans-serif;
    font-size: 14px;
    height: fit-content;
  }

  .card-2-no-border {
    border-radius: 10px;
    margin: 20px 0;
    margin-top: 10px;
    width: 100%;
    font-family: Arial, sans-serif;
    font-size: 14px;
    height: fit-content;
  }

  .row {
    display: flex;
    justify-content: space-between;
    padding: 6px 4px;
    border-bottom: 2px solid #757573;
  }

  .row:last-child {
    border-bottom: none;
  }

  .label {
    color: #555;
  }

  .value {
    font-weight: bold;
  }

  .dark {
    background-color: #959595;
    padding: 8px;
  }

  .dark-light {
    background-color: #bbbdc0;
    padding: 8px;
  }

  .container-tables {
    display: flex;
    justify-content: space-between;
    margin-top: 20px;
  }

  .container-graph {
    width: 48%;
    display: flex;
    flex-direction: column;
    align-items: start;
    margin-bottom: 10px;
  }
</style>
  <style>
    .container-graph-v2 {
